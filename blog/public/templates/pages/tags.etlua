<style>@import url('/css/header-card.css');</style>
<mdui-card variant="filled" class="header-card">
  <div class="header-title"><%= _h._("page_tags") %></div>
  <div class="header-content"><%= _h._("page_tags_desc") %></div>
</mdui-card>
<div class="tags-container">
<% for _, tag in ipairs(tags or {}) do %>
  <mdui-chip rounded href="/tags/<%= _h.url_encode(tag.name) %>">
    <%= _h.h(tag.name) %>
    <mdui-icon src="/icon/tag.svg" slot="icon"></mdui-icon>
  </mdui-chip>
<% end %>
</div>
