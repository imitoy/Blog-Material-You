# Blog Material You — 环境变量配置
# 复制此文件为 .env 并修改值
# cp .env.example .env

# 管理员用户名（默认：admin）
# BMY_ADMIN_USER=admin

# 管理员密码（默认：bmy2025）
# BMY_ADMIN_PASS=bmy2025

# Session Token HMAC 签名密钥（默认：bmy-session-secret-k8x9m2p4v6）
# 生产环境请使用随机字符串：python3 -c "import secrets; print(secrets.token_hex(32))"
# BMY_SESSION_SECRET=your-random-secret-here
